{
  "name": "nodejs-w-typescript-setup",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "NODE_OPTIONS=--max-old-space-size=460 tsc --incremental",
    "start:dev": "tsx --watch src/index.ts",
    "start:prod": "npm run build && npm start",
    "migrate:up": "tsx src/database/migrator.ts up",
    "migrate:latest": "tsx src/database/migrator.ts latest",
    "migrate:down": "tsx src/database/migrator.ts down",
    "migrate:baseline": "tsx src/database/migrator.ts baseline",
    "migrate:create": "tsx src/database/migrator.ts create"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.29.2",
    "mysql2": "^3.17.0",
    "redis": "^5.11.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
